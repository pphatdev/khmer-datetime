{
  "name": "@pphatdev/format-datetime",
  "version": "0.1.4",
  "description": "A robust utility to format dates and times into localized strings",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "module": "dist/index.mjs",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "unpkg": "dist/index.global.js",
  "jsdelivr": "dist/index.global.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm,iife --global-name FormatDateTimeBundle --dts --clean --minify",
    "test": "vitest run"
  },
  "keywords": [
    "datetime",
    "format",
    "date",
    "time"
  ],
  "author": "PPhat <hi@pphat.top>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pphatdev/format-datetime.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "bugs": {
    "url": "https://github.com/pphatdev/format-datetime/issues"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
